{
  "manifest_version": 3,
  "name": "Cursor Token 获取助手",
  "version": "1.0.0",
  "description": "一键从 cursor.com 获取 Access Token，支持屏幕阅读器",
  "permissions": [
    "cookies",
    "clipboardWrite",
    "storage"
  ],
  "host_permissions": [
    "https://cursor.com/*",
    "https://*.cursor.com/*",
    "https://token.cursorpro.com.cn/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cursor Token 获取助手"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
